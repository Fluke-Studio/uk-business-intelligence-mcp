{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "src/mcp/**/*.ts",
    "src/lib/adapters/**/*.ts",
    "src/lib/services/**/*.ts",
    "src/lib/schemas/**/*.ts",
    "src/lib/supabase/**/*.ts",
    "src/lib/config/**/*.ts",
    "src/lib/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "src/app"]
}
